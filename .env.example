# Supabase Edge Function AI proxy placeholders.
# Copy to a local .env.local file for local testing. Do not commit real secrets.

OPENAI_API_KEY=replace_with_your_openai_api_key
OPENAI_MODEL=gpt-4.1-mini
AI_PROXY_MAX_INPUT_CHARS=6000
AI_PROXY_ENABLE_DEBUG_LOGS=false

# RevenueCat public SDK key placeholders.
# Do not commit private RevenueCat API keys.
REVENUECAT_ANDROID_PUBLIC_API_KEY=replace_with_android_store_public_sdk_key
REVENUECAT_TEST_STORE_API_KEY=replace_with_test_store_public_sdk_key
USE_REVENUECAT_TEST_STORE=false
